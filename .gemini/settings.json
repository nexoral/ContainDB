{
  "version": "1.0",
  "description": "Gemini CLI settings for ContainDB",

  "project": {
    "name": "ContainDB",
    "type": "CLI Tool",
    "language": "Go",
    "runtime": "Go ≥1.18"
  },

  "context": {
    "fileName": ["GEMINI.md"],
    "hierarchical": true
  },

  "tools": {
    "enabled": ["codeSearch", "fileOperations", "shellCommands"]
  },

  "features": {
    "codeCompletion": true,
    "codeGeneration": true,
    "debugging": true,
    "refactoring": true,
    "testing": true
  }
}
