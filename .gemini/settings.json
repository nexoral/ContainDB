{
  "version": "1.0",
  "description": "Gemini CLI settings for ContainDB",

  "project": {
    "name": "ContainDB",
    "type": "CLI Tool",
    "language": "Go",
    "runtime": "Go ≥1.18"
  },

  "model": {
    "name": "gemini-3-pro",
    "temperature": 0.2,
    "maxTokens": 8192
  },

  "context": {
    "fileName": ["GEMINI.md"],
    "hierarchical": true
  },

  "tools": {
    "enabled": ["codeSearch", "fileOperations", "shellCommands"]
  },

  "features": {
    "codeCompletion": true,
    "codeGeneration": true,
    "debugging": true,
    "refactoring": true,
    "testing": true
  }
}
